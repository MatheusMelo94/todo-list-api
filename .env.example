# todo-list-api — exemplo de variaveis de ambiente
# Copie para .env e ajuste os valores. NUNCA versione o .env real.

# URI de conexao MongoDB.
# Formato: mongodb://[usuario:senha@]host:porta/banco
# Local (default do profile local): mongodb://localhost:27017/todolist
MONGODB_URI=mongodb://localhost:27017/todolist

# Profile Spring ativo: local | docker | prod
SPRING_PROFILES_ACTIVE=local

# Allowlist de origens permitidas para CORS (PDR-0003).
# Origens separadas por virgula. NUNCA use '*'.
# Ex.: https://app.exemplo.com,https://admin.exemplo.com
CORS_ALLOWED_ORIGINS=http://localhost:3000
